# ── LLM (GitHub Models) ──────────────────────────────────────────────────────
# Get your token at https://github.com/settings/tokens
# Required scopes: none (public models are free)
GITHUB_TOKEN=your_github_token_here

# Model to use for worker agents (data, training, evaluation, deployment)
GITHUB_MODEL=openai/gpt-4.1-mini

# ── MLflow ───────────────────────────────────────────────────────────────────
# For local development use SQLite (no server needed).
# For Docker stack use: http://localhost:5000
MLFLOW_TRACKING_URI=sqlite:///./mlflow.db
MLFLOW_EXPERIMENT_NAME=mlops-agents

# ── Optional: LangSmith tracing ──────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=mlops-multi-agent

# ── Optional: fallback LLM providers (if GitHub rate limit is hit) ────────────
# GROQ_API_KEY=
# GEMINI_API_KEY=

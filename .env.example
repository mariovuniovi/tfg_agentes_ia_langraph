# =============================================================================
# GitHub Models — free LLM inference
# Get token: GitHub Settings → Developer settings → Fine-grained tokens
# Required permission: Account → Models → Read-only
# Model list: https://github.com/marketplace/models
# =============================================================================
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL=openai/gpt-4.1-mini

# =============================================================================
# Fallback LLM providers (optional — only if GitHub rate limit is hit)
# =============================================================================
# GROQ_API_KEY=your_groq_key_here      # 1000 RPD free at console.groq.com
# GEMINI_API_KEY=your_gemini_key_here  # 250 RPD free at ai.google.dev

# =============================================================================
# MLflow
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=mlops-agents

# =============================================================================
# LangSmith (optional — agent tracing and debugging)
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mlops-multi-agent

# =============================================================================
# Application
# =============================================================================
LOG_LEVEL=INFO
DATA_DIR=./data/samples

# ============================================================
# LLM — OpenAI API (única variable obligatoria)
# Consigue tu clave en: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# GRATIS: GitHub Models (endpoint compatible con OpenAI)
# Descomenta estas 3 y pon un GitHub token en OPENAI_API_KEY.
# ------------------------------------------------------------
#OPENAI_BASE_URL=https://models.github.ai/inference
#OPENAI_MODEL_OVERRIDE=openai/gpt-4.1-mini

# ------------------------------------------------------------
# Overrides opcionales (defaults sensatos en config/settings.py)
# ------------------------------------------------------------
# Modelo fallback (los modelos por agente van en prompts/*.yaml)
#OPENAI_MODEL=gpt-5.4-mini

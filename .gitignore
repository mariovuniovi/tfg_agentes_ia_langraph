# UV / Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.so

# Environment — NEVER commit real credentials
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tools
.mypy_cache/
.pytest_cache/
.ruff_cache/

# MLflow local artifacts
mlruns/
mlartifacts/
mlflow.db
checkpoints.db
evidently_workspace/

# Data — large raw files
data/raw/
data/uploads/
*.parquet
*.pkl
*.joblib

# Notebooks checkpoints
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Pipeline-generated data dirs
data/merged/
data/processed/
data/working/

# SP3 — model training artifacts (generated at runtime)
catboost_info/
/models/
experience_pool/
# Pool DB ships seeded as a reproducibility fixture; other runtime writes stay ignored
storage/*
!storage/mlops_metadata.db

# SP4 — benchmark split outputs (CSVs commit, splits do not)
data/benchmarks/_splits/

# Agentic cost measurement dumps (EventLogs, diagnostics, revalidation runs)
data/benchmarks/cost_runs*/
data/benchmarks/diag/
data/benchmarks/revalidate/
data/benchmarks/*.log

# Pipeline byproducts written next to sample inputs (parse_datetime_column)
data/samples/**/*_parsed.csv

# Rewritten by data_validator_node on every run (schema persistence)
data/schema/uploaded_schema.json

# Scratch directory
.tmp/

# Raw Dominick's download (875 MB) — regenerated by the dataset loader; only the
# processed dominicks_cookies.csv is committed (source_id in the manifests)
data/benchmarks/dominicks_cookies_raw.csv

# SP2 — temporal gap reports
artifacts/

# Log files (rotation-managed, not committed)
logs/*.log
logs/*.log.*

# Migration rollback backups — insurance during a migration, redundant with
# git history afterwards; the plan/ and run/ docs commit, baseline/ does not
migrations/*/baseline/
